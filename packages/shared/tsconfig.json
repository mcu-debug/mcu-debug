{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "types": ["node"],
    "declaration": true,
    "rootDir": ".",
    "outDir": "lib",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["src/**/*", "dasm-helper/**/*.ts", "proxy-protocol/**/*.ts", "serial-helper/**/*.ts"],
  "exclude": ["lib", "node_modules"]
}
