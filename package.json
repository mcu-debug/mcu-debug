{
  "name": "mcu-debug-monorepo",
  "private": true,
  "workspaces": [
    "packages/shared",
    "packages/mcu-debug",
    "packages/mcu-debug-proxy"
  ],
  "scripts": {
    "watch": "npm run watch --workspaces",
    "build": "npm run build --workspaces",
    "compile": "npm run compile --workspace=packages/shared --workspace=packages/mcu-debug --workspace=packages/mcu-debug-proxy",
    "version:bump-extensions": "node ./scripts/bump-extensions-version.js",
    "build:types": "node scripts/run-sh.js scripts/generate-types.sh",
    "build:extensions": "npm run build --workspace=packages/mcu-debug --workspace=packages/mcu-debug-proxy",
    "package": "node scripts/run-sh.js scripts/package-extensions.sh",
    "test": "npm run test --workspaces"
  },
  "devDependencies": {
    "esbuild": "^0.27.3",
    "typescript": "^5.3.0",
    "typescript-strict-plugin": "^2.4.4"
  },
  "dependencies": {
    "@vscode/codicons": "^0.0.44"
  }
}
