{
  "name": "mcu-debug-monorepo",
  "private": true,
  "workspaces": [
    "packages/shared",
    "packages/mcu-debug",
    "packages/mcu-debug-proxy",
    "packages/mcu-debug/src/webviews/cockpit"
  ],
  "scripts": {
    "watch": "npm run watch --workspaces --if-present",
    "build": "npm run build --workspaces --if-present",
    "compile": "npm run version:sync && npm run compile --workspaces --if-present",
    "check:shared-package:exports": "node scripts/check-shared-package-exports.js",
    "check:shared-package": "npm run compile --workspace=packages/shared && npm run check:shared-package:exports && npm run update-commit-hash --workspace=packages/mcu-debug && npm run check-types --workspace=packages/mcu-debug && npm run check-types --workspace=packages/mcu-debug-proxy",
    "version:sync": "node ./scripts/sync-versions.js",
    "build:types": "node scripts/run-sh.js scripts/generate-types.sh",
    "build:extensions": "node scripts/sync-versions.js && npm run build --workspace=packages/mcu-debug --workspace=packages/mcu-debug-proxy",
    "package": "node scripts/run-sh.js scripts/package-extensions.sh",
    "test": "npm run test --workspaces --if-present"
  },
  "devDependencies": {
    "esbuild": "^0.28.0",
    "typescript": "6.0.3",
    "typescript-strict-plugin": "^2.4.4"
  },
  "dependencies": {
    "@vscode/codicons": "^0.0.44",
    "@vscode/vsce": "^3.9.1"
  }
}
